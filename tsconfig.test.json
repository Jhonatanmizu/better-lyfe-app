{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@shared/*": ["src/modules/shared/*"],
      "@utils/*": ["src/modules/utils/*"],
      "@assets/*": ["src/assets/*"],
      "@services/*": ["src/services/*"],
      "@hooks/*": ["src/modules/hooks/*"],
      "@config/*": ["src/modules/config/*"],
      "@store/*": ["src/store/*"]
    }
  },
  "include": ["src/**/*", "__tests__/**/*"]
}
